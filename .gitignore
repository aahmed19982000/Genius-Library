# Python bytecode / optimized files
*.pyc
**/__pycache__/

# Database
db.sqlite3

# Environment & Virtual Envs
.env
.venv/
venv/
ENV/

# IDEs
.vscode/
.idea/

# Logs
*.log

# Django static & media files
staticfiles/
media/

# Ignore all migrations (but keep __init__.py)
**/migrations/*
!**/migrations/__init__.py

# Protective: Ignore main settings to protect SECRET_KEY and Credentials
**/settings.py

# Git text settings
* text=auto